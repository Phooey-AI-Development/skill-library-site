---
import '../styles/global.css';
import ThemeToggle from '../components/ThemeToggle.tsx';

interface Props {
  title: string;
}
const { title } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <!-- Theme init must run before first paint to avoid a flash of wrong theme -->
    <script is:inline src={`${base}/theme-init.js`}></script>
  </head>
  <body>
    <header class="site-header">
      <nav>
        <a href={base || '/'} class="brand">
          <img src={`${base}/phooeycorp-logo.png`} alt="PhooeyCorp" class="brand-logo" />
          <span class="brand-divider"></span>
          <span class="brand-text">AI Skill Library</span>
        </a>
        <span class="env-badge">PROOF OF CONCEPT</span>
        <div class="header-spacer"></div>
        <a
          class="submit-btn"
          href="https://github.com/Phooey-AI-Development/AI-skills-library/issues/new?template=submit-skill.yml"
          target="_blank"
          rel="noopener"
          title="Submit a new skill for review"
        >
          + Submit a skill
        </a>
        <ThemeToggle client:load />
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="footer-content">
        <img src={`${base}/phooeycorp-logo.png`} alt="PhooeyCorp" class="footer-logo" />
        <p>
          Internal POC · Skills source:
          <a href="https://github.com/Phooey-AI-Development/AI-skills-library">AI-skills-library</a>
        </p>
      </div>
    </footer>
  </body>
</html>
